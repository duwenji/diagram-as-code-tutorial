digraph ClusterDemo {
  rankdir=LR;
  fontname="Meiryo";
  node [fontname="Meiryo"];
  edge [fontname="Meiryo"];

  subgraph cluster_agent {
    label="AIエージェント";
    style=dashed;
    Planner;
    Executor;
    Planner -> Executor;
  }

  subgraph cluster_tools {
    label="外部ツール";
    style=dashed;
    ToolA;
    ToolB;
  }

  Executor -> ToolA;
  Executor -> ToolB;
}
